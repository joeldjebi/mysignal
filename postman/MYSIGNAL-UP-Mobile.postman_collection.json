  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "verificationToken", "value": "" },
    { "key": "phone", "value": "0700000000" },
    { "key": "password", "value": "12345678" },
    { "key": "publicUserTypeId", "value": "1" },
    { "key": "publicUserTypeCode", "value": "UP" },
    { "key": "applicationId", "value": "1" },
    { "key": "applicationCode", "value": "MON_NRJ" },
    { "key": "organizationId", "value": "1" },
    { "key": "organizationTypeId", "value": "1" },
    { "key": "countryId", "value": "1" },
    { "key": "cityId", "value": "1" },
    { "key": "communeId", "value": "1" },
    { "key": "communeName", "value": "Cocody" },
    { "key": "serviceCategory", "value": "Internet" },
    { "key": "meterId", "value": "" },
    { "key": "reportId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "subscriptionPaymentId", "value": "" },
