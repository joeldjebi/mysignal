    {
      "name": "06 - Signalements",
      "item": [
        {
          "name": "List Reports",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/v1/public/reports"
          }
        },
        {
          "name": "Create Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.report?.id) pm.environment.set('reportId', json.data.report.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meter_id\": {{meterId}},\n  \"application_id\": {{applicationId}},\n  \"organization_id\": {{organizationId}},\n  \"country_id\": {{countryId}},\n  \"city_id\": {{cityId}},\n  \"commune_id\": {{communeId}},\n  \"signal_code\": \"NETWORK_OUTAGE\",\n  \"description\": \"Coupure depuis 2 heures\",\n  \"address\": \"Rue 12\",\n  \"occurred_at\": \"2026-04-10T12:00:00Z\",\n  \"latitude\": 5.348,\n  \"longitude\": -4.001,\n  \"location_source\": \"gps\",\n  \"signal_payload\": {\n    \"service_category\": \"{{serviceCategory}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}/v1/public/reports"
          }
        },
        {
          "name": "Create Report With Dynamic Fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
