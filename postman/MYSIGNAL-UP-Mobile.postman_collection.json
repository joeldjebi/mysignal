{
  "info": {
    "_postman_id": "d9fc140d-3013-4373-b6cf-cd1fbc59c205",
    "name": "MYSIGNAL UP Mobile API",
    "description": "Collection Postman pour l integration mobile des usagers publics (UP). Elle couvre l authentification OTP, la gestion du profil, des compteurs, des foyers Gonhi, des signalements, des paiements, des abonnements UP, des dossiers contentieux et des retours d experience.",
