  "item": [
    {
      "name": "01 - Catalogues publics",
      "description": "Routes accessibles sans authentification pour initialiser les catalogues de l application mobile.",
      "item": [
        {
          "name": "Applications",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const applications = json?.data?.applications || [];",
                  "pm.test('Applications returned', function () { pm.expect(applications.length).to.be.greaterThan(0); });",
                  "const selected = applications.find((application) => application.code === (pm.environment.get('applicationCode') || 'MON_NRJ')) || applications[0];",
                  "if (selected?.id) pm.environment.set('applicationId', selected.id);",
                  "if (selected?.code) pm.environment.set('applicationCode', selected.code);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/v1/public/applications",
            "description": "Retourne la liste des applications actives pour les formulaires mobiles."
          }
        },
        {
          "name": "Application Types",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const applicationTypes = json?.data?.application_types || [];",
                  "pm.test('Application types returned', function () { pm.expect(applicationTypes.length).to.be.greaterThan(0); });",
                  "const selected = applicationTypes[0];",
                  "if (selected?.id) pm.environment.set('organizationTypeId', selected.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/v1/public/application-types",
            "description": "Retourne les types d organisations exposes a l application mobile."
          }
        },
        {
          "name": "Organization Types",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/v1/public/organization-types",
            "description": "Alias explicite des types d organisations actifs."
          }
        },
        {
          "name": "Organizations",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const organizations = json?.data?.organizations || [];",
                  "pm.test('Organizations returned', function () { pm.expect(organizations.length).to.be.greaterThan(0); });",
                  "const selected = organizations[0];",
                  "if (selected?.id) pm.environment.set('organizationId', selected.id);",
                  "if (selected?.organization_type?.id) pm.environment.set('organizationTypeId', selected.organization_type.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/v1/public/organizations?application_id={{applicationId}}",
            "description": "Retourne les organisations actives, filtrables par application ou type d organisation."
          }
        },
        {
          "name": "Countries",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const countries = json?.data?.countries || [];",
                  "pm.test('Countries returned', function () { pm.expect(countries.length).to.be.greaterThan(0); });",
