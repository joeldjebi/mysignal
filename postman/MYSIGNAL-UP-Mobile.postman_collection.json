          }
        },
        {
          "name": "User Types",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const userTypes = json?.data?.user_types || [];",
                  "pm.test('User types returned', function () { pm.expect(userTypes.length).to.be.greaterThan(0); });",
                  "const selected = userTypes.find((type) => type.code === (pm.environment.get('publicUserTypeCode') || 'UP')) || userTypes[0];",
                  "if (selected?.id) pm.environment.set('publicUserTypeId', selected.id);",
                  "if (selected?.code) pm.environment.set('publicUserTypeCode', selected.code);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/v1/public/user-types",
            "description": "Retourne les types de comptes UP actifs pour la creation de compte mobile, avec la regle tarifaire associee."
          }
        }
      ]
    },
    {
      "name": "02 - Auth UP",
      "description": "Workflow OTP puis creation de compte ou connexion.",
      "item": [
        {
          "name": "Request OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.phone) pm.environment.set('phone', json.data.phone);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": "{{baseUrl}}/v1/public/auth/request-otp",
            "description": "Demande un OTP. En local, le code de test peut etre retourne."
          }
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.verification_token) pm.environment.set('verificationToken', json.data.verification_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"code\": \"1234\"\n}"
            },
            "url": "{{baseUrl}}/v1/public/auth/verify-otp",
            "description": "Verifie le code OTP et stocke verificationToken."
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.access_token) pm.environment.set('accessToken', json.data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"public_user_type_id\": {{publicUserTypeId}},\n  \"first_name\": \"Jean\",\n  \"last_name\": \"Doe\",\n  \"phone\": \"{{phone}}\",\n  \"commune\": \"{{communeName}}\",\n  \"password\": \"{{password}}\",\n  \"password_confirmation\": \"{{password}}\",\n  \"verification_token\": \"{{verificationToken}}\"\n}"
            },
            "url": "{{baseUrl}}/v1/public/auth/register",
            "description": "Cree un compte UP et retourne directement un access token."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json?.data?.access_token) pm.environment.set('accessToken', json.data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/v1/public/auth/login",
            "description": "Connexion classique UP."
          }
        }
      ]
    },
