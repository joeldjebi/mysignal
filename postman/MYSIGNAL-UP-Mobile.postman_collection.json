                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "const categories = json?.data?.service_categories || [];",
                  "pm.test('Service categories returned', function () { pm.expect(categories.length).to.be.greaterThan(0); });",
                  "const selected = categories.find((category) => category.name === (pm.environment.get('serviceCategory') || 'Internet')) || categories[0];",
                  "if (selected?.name) pm.environment.set('serviceCategory', selected.name);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/v1/public/service-categories?application_id={{applicationId}}&organization_id={{organizationId}}",
            "description": "Retourne les categories de service derivees des types de signaux et filtrables par application ou organisation."
          }
        },
